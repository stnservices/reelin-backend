# Database
DATABASE_URL=postgresql+asyncpg://reelin:reelin_dev@localhost:5432/reelin

# Security
SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# For mobile apps (longer-lived tokens)
MOBILE_ACCESS_TOKEN_EXPIRE_DAYS=7
MOBILE_REFRESH_TOKEN_EXPIRE_DAYS=30

# Application
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Storage (DigitalOcean Spaces / S3) - Leave empty for local development
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=

# Email (AWS SES SMTP) - Leave empty for local development
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL="ReelIn Notifications <noreply@reelin.ro>"
EMAIL_TIMEOUT=20
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_BACKOFF_SECONDS=2
SITE_NAME=ReelIn
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24

# Push Notifications (OneSignal) - Leave empty for local development
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# OAuth Providers - Leave empty if not using social login
# Google: https://console.cloud.google.com/ -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Facebook: https://developers.facebook.com/ -> Create App -> Facebook Login
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:3000

# reCAPTCHA v3 (Google) - For bot protection on auth forms
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_REQUIRED=false

# Error Monitoring (Sentry) - Leave empty for local development
SENTRY_DSN=
ENVIRONMENT=development
APP_VERSION=2.0.0
