# =============================================================================
# Reelin V2 - Production Environment Variables Template
# =============================================================================
# Copy this file and fill in the values before deployment.
# These values are configured in DigitalOcean App Platform dashboard.
#
# For local testing of production config:
#   cp deploy/.env.production.template .env.production
#   # Fill in values
#   export $(cat .env.production | xargs)
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (Auto-injected by DO App Platform as ${db.DATABASE_URL})
# -----------------------------------------------------------------------------
# Format: postgresql+asyncpg://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql+asyncpg://doadmin:PASSWORD@db-postgresql-fra1-xxxxx-do-user-xxxxx-0.b.db.ondigitalocean.com:25060/defaultdb?sslmode=require

# -----------------------------------------------------------------------------
# REDIS/VALKEY (Auto-injected by DO App Platform as ${redis.DATABASE_URL})
# -----------------------------------------------------------------------------
# Format: rediss://default:password@host:port
REDIS_URL=rediss://default:PASSWORD@valkey-fra1-xxxxx-do-user-xxxxx-0.b.db.ondigitalocean.com:25061

# -----------------------------------------------------------------------------
# SECURITY - Generate strong random keys!
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-min-32-chars-change-this
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars-change-this

# JWT Token expiration (seconds)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# DIGITALOCEAN SPACES (S3-compatible object storage)
# -----------------------------------------------------------------------------
# Create at: https://cloud.digitalocean.com/spaces
# Generate keys at: https://cloud.digitalocean.com/account/api/spaces
DO_SPACES_KEY=your-spaces-access-key
DO_SPACES_SECRET=your-spaces-secret-key
DO_SPACES_BUCKET=reelin-prod
DO_SPACES_REGION=fra1
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
DO_SPACES_CDN_ENDPOINT=https://reelin-prod.fra1.cdn.digitaloceanspaces.com

# -----------------------------------------------------------------------------
# STRIPE (Payment Processing)
# -----------------------------------------------------------------------------
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook secret - get after creating webhook endpoint
# Create at: https://dashboard.stripe.com/webhooks
# Endpoint URL: https://api.reelin.ro/api/v1/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Price IDs - create products in Stripe Dashboard
# Products > Add Product > Add Pricing
STRIPE_MONTHLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_YEARLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# FIREBASE (Push Notifications)
# -----------------------------------------------------------------------------
# Get from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Store as JSON string (escaped) or base64 encoded
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"reelin-xxxxx",...}

# -----------------------------------------------------------------------------
# APPLICATION CONFIG
# -----------------------------------------------------------------------------
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=api.reelin.ro,reelin.ro

# CORS origins (comma-separated)
CORS_ORIGINS=https://admin.reelin.ro,https://reelin.ro,https://www.reelin.ro

# API URL (for generating links in emails, etc.)
API_BASE_URL=https://api.reelin.ro
FRONTEND_BASE_URL=https://admin.reelin.ro

# -----------------------------------------------------------------------------
# ADMIN USER (Initial seed)
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@reelin.ro
ADMIN_PASSWORD=change-this-secure-password

# -----------------------------------------------------------------------------
# EMAIL (Optional - for transactional emails)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key
# SMTP_FROM_EMAIL=noreply@reelin.ro
# SMTP_FROM_NAME=ReelIn

# -----------------------------------------------------------------------------
# SENTRY (Optional - Error tracking)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=100

# =============================================================================
# FRONTEND ENVIRONMENT VARIABLES (.env.production for Next.js)
# =============================================================================
# These go in the frontend service, not backend:
#
# NEXT_PUBLIC_API_URL=https://api.reelin.ro
# NEXT_PUBLIC_APP_URL=https://admin.reelin.ro
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NODE_ENV=production
# =============================================================================
